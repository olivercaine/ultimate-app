{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "@ultimate/mobile": {
      "dependsOn": ["@ultimate/package#build"]
    },
    "@ultimate/new-web": {
      "dependsOn": ["@ultimate/package#build"]
    },
    "health-check": {}
  }
}
