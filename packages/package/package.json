{
  "name": "@ultimate/package",
  "version": "0.0.0",
  "description": "A simple tree-shakable TypeScript library boilerplate",
  "type": "module",
  "main": "dist/typescript-library-boilerplate.bundle.js",
  "jsnext:main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "concurrently 'npm install' 'npm run test:watch'",
    "dev:docker": "docker run --rm -it -w /app -v ${PWD}:/app $(docker build . -q) sh -c 'npm run dev'",
    "lint": "eslint -c .eslintrc.cjs --ext .ts src --quiet",
    "lint:fix": "npm run lint -- --fix",
    "test": "jest",
    "test:watch": "npm test -- --watch",
    "compile": "tsc",
    "build": "rimraf dist && tsc -p tsconfig-esm.json && rollup -c && cp README.md dist",
    "health-check": "time concurrently --group --kill-others-on-fail 'npm run lint' 'npm run compile' 'npm run build && node tools/build-test.mjs' 'npm test'",
    "health-check:docker": "docker run --rm -w /app -v ${PWD}:/app $(docker build . -q) sh -c 'npm ci && npm run health-check'",
    "commit": "git-cz"
  },
  "husky": {
    "hooks": {
      "post-commit": "npm run lint:fix",
      "pre-push": "npm run health-check"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/olivercaine/typescript-library-boilerplate.git"
  },
  "keywords": [
    "typescript",
    "boilerplate",
    "es2015",
    "mocha"
  ],
  "author": "olivercaine <olliecaine@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/olivercaine/typescript-library-boilerplate/issues"
  },
  "homepage": "https://github.com/olivercaine/typescript-library-boilerplate#readme",
  "devDependencies": {
    "@olliecaine/eslint-config": "^1.0.15",
    "@olliecaine/tsconfig": "^1.0.28",
    "@rollup/plugin-commonjs": "^25.0.8",
    "@rollup/plugin-node-resolve": "^15.3.1",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/jest": "^29.5.11",
    "@types/node": "10.17.60",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "commitizen": "4.3.0",
    "concurrently": "4.1.2",
    "cz-conventional-changelog": "2.1.0",
    "eslint": "^8.57.1",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-jsdoc": "^48.2.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-standard": "^5.0.0",
    "husky": "1.3.1",
    "jest": "^29.7.0",
    "rimraf": "2.7.1",
    "rollup": "^3.29.5",
    "shx": "0.3.4",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
