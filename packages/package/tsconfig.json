{
  "extends": "@olliecaine/tsconfig",
  "compilerOptions": { // https://www.typescriptlang.org/tsconfig
    "baseUrl": "src", // Set a base directory to resolve non-absolute module names.
    "diagnostics": true, // Used to output diagnostic information for debugging
    "esModuleInterop": true, // Import non-ES modules as default imports.
    "lib": [
      "es2015"
    ],
    "module": "commonjs", // https://www.typescriptlang.org/tsconfig#module
    "noImplicitAny": false, // Don't throw errors by falling back to type any for JS imports https://www.typescriptlang.org/tsconfig#noImplicitAny
    "outDir": "./dist", // If specified, .js (as well as .d.ts, .js.map, etc.) files will be emitted into this directory.
    "types": [
      "jest",
      "node"
    ]
  },
  "files": [
    "src/index.ts"
  ]
}